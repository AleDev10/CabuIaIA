{
    "manifest_version":3,
    "name":"CabulaIA",
    "version":"1.0",
    "description": "uma extenção para o navegardor chrome que usa os recursos de uma IA para interpretar o contexto de uma pagina web",
    "action":{
        "default_title":"CabulaIA",
        "default_icon":"assets/icone.png"
    },
    "side_panel":{
        "default_path":"extencao.html",
        "default_icon":"assets/icone.png"
    },
    "permissions":[
        "activeTab",
        "sidePanel"
    ],
    "host_permissions":[
        "<all_urls>"
    ],
    "background":{
        "service_worker":"background.js"
    },
    "content_scripts":[
        {
            "matches":[
                "<all_urls>"
            ],
            "js":[
                "content.js"
            ]
        }
    ]
}